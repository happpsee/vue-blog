.header 
  background-color #ffffff
  height  60px

.back-wrap
  position relative;
  width 100%
  height: 100%

.arrow-wrap
  position: absolute;
  left 10PX
  top 0PX
  display flex
  align-items center
  height: 100%;

.logo-wrap
  position: absolute;
  right 10PX
  top 0PX
  height: 100%;

.icon-logo
  display: block;
  width: 40px;
  height: 50px;
  background: url("logo.png");
  background-size: 100%;

.icon-arrow-left
  width: 18px;
  height: 18px;
  background: url("arrow-left.svg");
  background-size: 100%;

.back-text
  font-size 14px

.back
  width: 20px
  height: 20px

.back-title
  flex: 1
  display: flex
  align-items center
  justify-content center
  height: 100%
  font-size 18px

