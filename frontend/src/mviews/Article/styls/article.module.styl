

.article-list 
  height 100%;
  overflow: auto
  background-color f2f3f5

  &::-webkit-scrollbar
    display: none
  

.article-item
  margin-top: 10px
  background-color #ffffff

.content 
  display: flex
  align-items: flex-end
  column-gap: 5PX
  padding: 10PX

.cover
  flex: none;
  height 60px 
  width 60px

.cover :global(.van-image__img)
  width: 100%
  height: 100%

.right 
  flex: 1
  min-width: 0
  height: 100%
  color #4B5563
  border-radius: 8px

.title 
  width: 100%
  font-size 20PX

.summary
  width: 100%
  font-size 16PX

.divider
  font-size: 10PX
  --van-divider-margin: 2px
  --van-divider-text-color #4B5563
  --van-divider-border-color #4B5563





:global(.van-skeleton-paragraph)
  border-radius:8px