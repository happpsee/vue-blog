// 颜色变量
primary_color = #18181B
secondary_color = #3F3F46
cta_color = #4B5563
bg_color = #FAFAFA
text_color = #09090B
text_color_secondary = #3F3F46
border_color = #E5E7EB

// 字体
font_family = 'Archivo', 'Space Grotesk', sans-serif

// 间距
spacing_xs = 0.25rem
spacing_sm = 0.5rem
spacing_md = 1rem
spacing_lg = 1.5rem
spacing_xl = 2rem
spacing_2xl = 3rem

// 圆角
border_radius_sm = 0.25rem
border_radius_md = 0.375rem
border_radius_lg = 0.5rem
border_radius_xl = 0.75rem

// 阴影
shadow_sm = 0 1px 2px 0 rgba(0, 0, 0, 0.05)
shadow_md = 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)
shadow_lg = 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)

// 过渡
transition_default = all 0.2s ease-in-out

// 通用样式
ttColorCommon()
  color text_color

ttColorSecondary()
  color text_color_secondary

bgColorCommon()
  background-color bg_color

bgColorCard()
  background-color #FFFFFF

bd()
  border 1px solid border_color

bdRadius()
  border-radius border_radius_md

boxSdwCommon()
  box-shadow shadow_sm

boxSdwCard()
  box-shadow shadow_md
